# DeepSeek API Key (从 platform.deepseek.com 获取)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API Base URL (默认官方地址)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ZJU 统一认证 (仅 L4 阶段需要)
ZJU_USERNAME=你的学号
ZJU_PASSWORD=你的密码

# CC98 Token (从浏览器 DevTools 提取，仅 L5 阶段需要)
CC98_TOKEN=your-cc98-bearer-token

# 飞书 Webhook (仅 Phase 3 推送需要)
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 邮箱 (仅 Phase 3 邮件推送需要)
EMAIL_FROM=your_email@zju.edu.cn
EMAIL_TO=your_email@zju.edu.cn
EMAIL_PASSWORD=your_smtp_password
