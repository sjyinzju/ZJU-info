# ZJU Info Agent — 密钥文件模板
# 复制此文件为 .env 并填入真实值
# .env 不会被提交到 Git

# 大模型 API Key（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ZJU 统一认证（仅 L4 阶段需要）
ZJU_USERNAME=学号
ZJU_PASSWORD=密码

# CC98 Token（仅 L5 阶段需要，从浏览器 DevTools 提取）
CC98_TOKEN=

# 飞书 Webhook（可选推送）
FEISHU_WEBHOOK=

# 邮箱推送（可选）
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASSWORD=
